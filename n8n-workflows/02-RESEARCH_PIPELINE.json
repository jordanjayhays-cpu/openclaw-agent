{
  "name": "Research Pipeline",
  "nodes": [
    {
      "parameters": {
        "updates": true,
        "options": {}
      },
      "id": "telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "={{$json.text}}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "web-search-1",
      "name": "Web Search 1",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 200]
    },
    {
      "parameters": {
        "url": "=https://perplexity.ai/api/search?q={{$json.text}}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "web-search-2",
      "name": "Web Search 2",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 400]
    },
    {
      "parameters": {
        "jsCode": "// Aggregate research results\nconst results = [\n  { source: 'Search 1', data: $input.first() },\n  { source: 'Search 2', data: $input.last() }\n];\n\nreturn [{ json: { summary: 'Research aggregated', results } }];"
      },
      "id": "aggregate",
      "name": "Aggregate Results",
      "type": "n8n-nodes-base.code",
      "position": [750, 300]
    },
    {
      "parameters": {
        "chatId": "6463127078",
        "text": "=🔍 Research Complete!\n\nTopic: {{$json.text}}\n\nSummary saved to GitHub.",
        "additionalFields": {}
      },
      "id": "telegram-send",
      "name": "Notify via Telegram",
      "type": "n8n-nodes-base.telegram",
      "position": [1000, 300]
    }
  ],
  "connections": {
    "Telegram Trigger": {
      "main": [[{"node": "Web Search 1", "type": "main", "index": 0}]]
    },
    "Web Search 1": {
      "main": [[{"node": "Aggregate Results", "type": "main", "index": 0}]]
    },
    "Web Search 2": {
      "main": [[{"node": "Aggregate Results", "type": "main", "index": 0}]]
    },
    "Aggregate Results": {
      "main": [[{"node": "Notify via Telegram", "type": "main", "index": 0}]]
    }
  }
